{
  "name": "travel_approval",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-travelapproval": "cds watch --open travelapproval/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy travel_approval --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      }
    }
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "crendentials": "db/sqlite"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/travelapproval"
  ]
}